# -------------- Qt专属忽略规则 --------------
# 编译构建目录
build-*/
build/
debug/
release/
out/

# Qt自动生成的文件
moc_*.cpp
moc_*.h
qrc_*.cpp
ui_*.h
*.moc
*.qm
*.prl

# Qt Creator用户配置文件（个人本地配置，不需要上传）
*.pro.user
*.pro.user.*
*.qbs.user
*.qbs.user.*
CMakeLists.txt.user*
*.autosave
QtProject.conf

# -------------- C/C++编译产物 --------------
*.o
*.obj
*.a
*.so
*.so.*
*.dll
*.exe
*.lib
*.dylib
*.la
*.lai
*.slo
*.lo

# -------------- 系统/IDE临时文件 --------------
.DS_Store
Thumbs.db
.idea/
.vscode/
.vs/
*~
*.bak
*.tmp
*.swp

# -------------- Makefile/构建脚本 --------------
Makefile*
/.qmake.cache
/.qmake.stash
cmake_install.cmake
CMakeCache.txt
CMakeFiles/
compile_commands.json